# ─────────────────────────────────────────────────────────────────────────────
# RFO Protocol Engine — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# NEVER hardcode secrets in docker-compose.yml.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=rfo_protocol
POSTGRES_USER=rfo
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_PORT=5432

# ── Security (REQUIRED) ─────────────────────────────────────────────────────
# Secret key for HMAC site ID generation. Generate with:
#   openssl rand -hex 32
RFO_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# API Keys for client authentication (comma-separated: name:key)
# Generate keys with: openssl rand -hex 16
# Format: name:key,name:key  (colon separator, NOT equals)
RFO_API_KEYS=agent_alpha:CHANGE_ME_KEY_1,agent_beta:CHANGE_ME_KEY_2

# ── Server ───────────────────────────────────────────────────────────────────
ENGINE_PORT=3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins. Use * for development only.
RFO_CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# ── DDoS Protection ─────────────────────────────────────────────────────────
RFO_DDOSS_MAX_PER_IP=100
RFO_DDOSS_MAX_GLOBAL=1000

# ── Logging ──────────────────────────────────────────────────────────────────
# Options: trace, debug, info, warn, error
# Per-module: RUST_LOG=info,rfo_core=debug,tower_http=debug
RUST_LOG=info
